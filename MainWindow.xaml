<Window
    x:Class="DroidTidal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DroidTidal"
    Title="DroidTidal">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="DroidTidal"
                       VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.6"/>
        </Grid>

        <!-- Main Content Area -->
        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        IsBackButtonVisible="Auto"
                        IsBackEnabled="{x:Bind ContentFrame.CanGoBack, Mode=OneWay}"
                        BackRequested="NavView_BackRequested"
                        ItemInvoked="NavView_ItemInvoked"
                        PaneDisplayMode="Left"
                        OpenPaneLength="200"
                        IsSettingsVisible="True">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="Home" Icon="Home"/>
                <NavigationViewItem Content="Search" Tag="Search" Icon="Find"/>
                <NavigationViewItem Content="Library" Tag="Library" Icon="Library"/>
                <NavigationViewItem Content="Queue" Tag="Queue" Icon="List"/>
                <NavigationViewItem Content="Lyrics" Tag="Lyrics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEE71;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <!-- Floating Player Bar -->
        <Border Grid.Row="2"
                x:Name="PlayerBar"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Track Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center" MinWidth="200">
                    <Border Width="40" Height="40" CornerRadius="4">
                        <Image x:Name="PlayerCoverArt" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="PlayerTrackTitle" Text="No track playing"
                                   FontSize="13" FontWeight="SemiBold"
                                   MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="PlayerArtistName" Text=""
                                   FontSize="11" Opacity="0.6"
                                   MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <!-- Playback Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                    <Button x:Name="ShuffleBtn" Click="ShuffleBtn_Click"
                            Style="{StaticResource SubtleButtonStyle}" Width="32" Height="32">
                        <FontIcon Glyph="&#xE8B1;" FontSize="14"/>
                    </Button>
                    <Button x:Name="PrevBtn" Click="PrevBtn_Click"
                            Style="{StaticResource SubtleButtonStyle}" Width="32" Height="32">
                        <FontIcon Glyph="&#xE892;" FontSize="16"/>
                    </Button>
                    <Button x:Name="PlayPauseBtn" Click="PlayPauseBtn_Click"
                            Width="40" Height="40" CornerRadius="20"
                            HorizontalAlignment="Center">
                        <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="18"/>
                    </Button>
                    <Button x:Name="NextBtn" Click="NextBtn_Click"
                            Style="{StaticResource SubtleButtonStyle}" Width="32" Height="32">
                        <FontIcon Glyph="&#xE893;" FontSize="16"/>
                    </Button>
                    <Button x:Name="RepeatBtn" Click="RepeatBtn_Click"
                            Style="{StaticResource SubtleButtonStyle}" Width="32" Height="32">
                        <FontIcon x:Name="RepeatIcon" Glyph="&#xE8EE;" FontSize="14"/>
                    </Button>
                </StackPanel>

                <!-- Progress + Volume -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" MinWidth="200" HorizontalAlignment="Right">
                    <TextBlock x:Name="PositionText" Text="0:00"
                               FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                    <Slider x:Name="ProgressSlider" Width="120" Minimum="0"
                            VerticalAlignment="Center"
                            ValueChanged="ProgressSlider_ValueChanged"/>
                    <TextBlock x:Name="DurationText" Text="0:00"
                               FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                    <FontIcon Glyph="&#xE767;" FontSize="14" Opacity="0.6"
                              VerticalAlignment="Center"/>
                    <Slider x:Name="VolumeSlider" Width="80" Minimum="0" Maximum="100" Value="100"
                            VerticalAlignment="Center"
                            ValueChanged="VolumeSlider_ValueChanged"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
