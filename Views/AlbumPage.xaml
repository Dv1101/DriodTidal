<Page
    xmlns:helpers="using:DroidTidal.Helpers"
    x:Class="DroidTidal.Views.AlbumPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DroidTidal.Models"
    NavigationCacheMode="Disabled">
    <Page.Resources>
        <helpers:StringToVisibilityConverter x:Key="StringVisibility"/>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="0,0,0,100">
            <!-- Loading -->
            <ProgressRing x:Name="LoadingRing" IsActive="False" HorizontalAlignment="Center" Margin="0,60"/>

            <!-- Album Header -->
            <Grid x:Name="AlbumHeader" Margin="0,0,0,24" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="12" Width="220" Height="220" Margin="0,0,24,0">
                    <Border.Background>
                        <ImageBrush x:Name="AlbumCover" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                    <TextBlock x:Name="AlbumType" Text="ALBUM" FontSize="12" FontWeight="SemiBold"
                               Opacity="0.5" CharacterSpacing="80"/>
                    <TextBlock x:Name="AlbumTitle" Style="{StaticResource DisplayTitle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <HyperlinkButton x:Name="AlbumArtist" Content="" Click="ArtistLink_Click"
                                         Padding="0" FontSize="14"/>
                        <TextBlock x:Name="AlbumMeta" Opacity="0.6" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                        <Button x:Name="PlayAllBtn" Click="PlayAll_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE768;" FontSize="14"/>
                                <TextBlock Text="Play"/>
                            </StackPanel>
                        </Button>
                        <Button Click="ShufflePlay_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B1;" FontSize="14"/>
                                <TextBlock Text="Shuffle"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="FavoriteBtn" Click="Favorite_Click" Style="{StaticResource TransparentButton}">
                            <FontIcon x:Name="FavoriteIcon" Glyph="&#xEB51;" FontSize="18"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Track List -->
            <ListView x:Name="TrackList" IsItemClickEnabled="True" ItemClick="TrackItem_Click"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Track">
                        <Grid Height="48" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind TrackNumber}"
                                       VerticalAlignment="Center" Opacity="0.5" FontSize="13"
                                       TextAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource TrackTitle}"/>
                                <TextBlock Text="{x:Bind ArtistName}" Style="{StaticResource TrackSubtitle}"
                                           Visibility="{x:Bind ArtistName, Converter={StaticResource StringVisibility}}"/>
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource QualityBadge}"
                                    Visibility="{x:Bind QualityBadge, Converter={StaticResource StringVisibility}}"
                                    Margin="8,0">
                                <TextBlock Text="{x:Bind QualityBadge}" Style="{StaticResource BadgeText}"/>
                            </Border>
                            <TextBlock Grid.Column="4" Text="{x:Bind DurationString}"
                                       VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                                       TextAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Similar Albums -->
            <TextBlock x:Name="SimilarHeader" Text="Similar Albums" Style="{StaticResource SectionHeader}"
                       Visibility="Collapsed"/>
            <GridView x:Name="SimilarGrid" ItemClick="SimilarAlbum_Click" IsItemClickEnabled="True"
                      SelectionMode="None">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:AlbumSearchResult">
                        <Border Style="{StaticResource CardBorder}" Width="160" Margin="4">
                            <StackPanel Spacing="8">
                                <Border CornerRadius="8" Height="140" Width="140">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{x:Bind CoverUrl}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource TrackTitle}" MaxWidth="140"/>
                                <TextBlock Text="{x:Bind ArtistName}" Style="{StaticResource TrackSubtitle}" MaxWidth="140"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>

