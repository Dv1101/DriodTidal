<Page
    xmlns:helpers="using:DroidTidal.Helpers"
    x:Class="DroidTidal.Views.ArtistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DroidTidal.Models"
    NavigationCacheMode="Disabled">
    <Page.Resources>
        <helpers:StringToVisibilityConverter x:Key="StringVisibility"/>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="0,0,0,100">
            <ProgressRing x:Name="LoadingRing" IsActive="False" HorizontalAlignment="Center" Margin="0,60"/>

            <!-- Artist Header -->
            <StackPanel x:Name="ArtistHeader" HorizontalAlignment="Center" Spacing="16" Margin="0,0,0,32"
                        Visibility="Collapsed">
                <Ellipse x:Name="ArtistImage" Width="180" Height="180" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ArtistName" Style="{StaticResource DisplayTitle}" TextAlignment="Center"
                           HorizontalAlignment="Center"/>
                <StackPanel x:Name="RoleBadges" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <Button Click="ShuffleAll_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B1;" FontSize="14"/>
                            <TextBlock Text="Shuffle Play"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Top Tracks -->
            <TextBlock x:Name="TopTracksHeader" Text="Top Tracks" Style="{StaticResource SectionHeader}"
                       Visibility="Collapsed"/>
            <ListView x:Name="TopTracksList" IsItemClickEnabled="True" ItemClick="TopTrack_Click"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Track">
                        <Grid Height="56" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="6" Width="44" Height="44">
                                <Border.Background>
                                    <ImageBrush ImageSource="{x:Bind SmallCoverUrl}" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource TrackTitle}"/>
                                <TextBlock Text="{x:Bind AlbumTitle}" Style="{StaticResource TrackSubtitle}"/>
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource QualityBadge}"
                                    Visibility="{x:Bind QualityBadge, Converter={StaticResource StringVisibility}}"
                                    Margin="8,0">
                                <TextBlock Text="{x:Bind QualityBadge}" Style="{StaticResource BadgeText}"/>
                            </Border>
                            <TextBlock Grid.Column="3" Text="{x:Bind DurationString}"
                                       VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                                       TextAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Albums -->
            <TextBlock x:Name="AlbumsHeader" Text="Albums" Style="{StaticResource SectionHeader}"
                       Visibility="Collapsed"/>
            <GridView x:Name="AlbumsGrid" ItemClick="AlbumItem_Click" IsItemClickEnabled="True"
                      SelectionMode="None">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:AlbumDetail">
                        <Border Style="{StaticResource CardBorder}" Width="160" Margin="4">
                            <StackPanel Spacing="8">
                                <Border CornerRadius="8" Height="140" Width="140">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{x:Bind CoverUrl}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource TrackTitle}" MaxWidth="140"/>
                                <TextBlock Text="{x:Bind Year}" Style="{StaticResource TrackSubtitle}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Similar Artists -->
            <TextBlock x:Name="SimilarHeader" Text="Similar Artists" Style="{StaticResource SectionHeader}"
                       Visibility="Collapsed"/>
            <GridView x:Name="SimilarGrid" ItemClick="SimilarArtist_Click" IsItemClickEnabled="True"
                      SelectionMode="None">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:ArtistSearchResult">
                        <StackPanel Width="140" Spacing="8" Margin="4" HorizontalAlignment="Center">
                            <Ellipse Width="120" Height="120">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{x:Bind ImageUrl}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource TrackTitle}"
                                       TextAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>

