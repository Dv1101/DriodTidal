<Page
    xmlns:helpers="using:DroidTidal.Helpers"
    x:Class="DroidTidal.Views.QueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DroidTidal.Models"
    Loaded="Page_Loaded">
    <Page.Resources>
        <helpers:StringToVisibilityConverter x:Key="StringVisibility"/>
    </Page.Resources>

    <Grid Padding="0,0,0,100">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Queue" Style="{StaticResource PageHeader}" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <TextBlock x:Name="QueueCount" Opacity="0.6" VerticalAlignment="Center"/>
            <Button Content="Clear Queue" Click="ClearQueue_Click" Visibility="Collapsed"
                    x:Name="ClearBtn"/>
        </StackPanel>

        <ListView x:Name="QueueList" Grid.Row="2" IsItemClickEnabled="True"
                  ItemClick="QueueItem_Click" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Track">
                    <Grid Height="56" Padding="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="6" Width="44" Height="44">
                            <Border.Background>
                                <ImageBrush ImageSource="{x:Bind SmallCoverUrl}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource TrackTitle}"/>
                            <TextBlock Style="{StaticResource TrackSubtitle}">
                                <Run Text="{x:Bind ArtistName}"/>
                                <Run Text=" • "/>
                                <Run Text="{x:Bind AlbumTitle}"/>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="2" Style="{StaticResource QualityBadge}"
                                Visibility="{x:Bind QualityBadge, Converter={StaticResource StringVisibility}}"
                                Margin="8,0">
                            <TextBlock Text="{x:Bind QualityBadge}" Style="{StaticResource BadgeText}"/>
                        </Border>
                        <TextBlock Grid.Column="3" Text="{x:Bind DurationString}"
                                   VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                                   TextAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty State -->
        <StackPanel x:Name="EmptyState" Grid.Row="2" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Spacing="12" Visibility="Collapsed">
            <FontIcon Glyph="&#xE90B;" FontSize="48" Opacity="0.3"/>
            <TextBlock Text="Queue is empty" FontSize="16" Opacity="0.5"/>
        </StackPanel>
    </Grid>
</Page>

