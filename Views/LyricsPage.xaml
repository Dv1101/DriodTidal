<Page
    x:Class="DroidTidal.Views.LyricsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DroidTidal.Models"
    Loaded="Page_Loaded">

    <Grid Padding="0,0,0,100">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="Lyrics" Style="{StaticResource PageHeader}"/>
            <TextBlock x:Name="TrackInfo" Style="{StaticResource TrackSubtitle}" FontSize="14"/>
        </StackPanel>

        <!-- Loading -->
        <ProgressRing x:Name="LoadingRing" Grid.Row="1" IsActive="False"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Synced Lyrics -->
        <ListView x:Name="SyncedList" Grid.Row="1" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:LyricLine">
                    <TextBlock Text="{x:Bind Text}" FontSize="20" FontWeight="SemiBold"
                               Padding="0,8" TextWrapping="Wrap" Opacity="0.4"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Plain Lyrics -->
        <ScrollViewer x:Name="PlainLyricsScroll" Grid.Row="1" Visibility="Collapsed">
            <TextBlock x:Name="PlainLyricsText" FontSize="16" TextWrapping="Wrap"
                       LineHeight="28" Padding="0,8"/>
        </ScrollViewer>

        <!-- Error / No Lyrics -->
        <StackPanel x:Name="ErrorState" Grid.Row="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Spacing="12" Visibility="Collapsed">
            <FontIcon Glyph="&#xE8D7;" FontSize="48" Opacity="0.3"/>
            <TextBlock x:Name="ErrorText" FontSize="16" Opacity="0.5" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
