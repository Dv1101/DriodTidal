<Page
    xmlns:helpers="using:DroidTidal.Helpers"
    x:Class="DroidTidal.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DroidTidal.Models"
    Loaded="Page_Loaded">
    <Page.Resources>
        <helpers:StringToVisibilityConverter x:Key="StringVisibility"/>
    </Page.Resources>

    <Grid Padding="0,0,0,100">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Library" Style="{StaticResource PageHeader}" Grid.Row="0"/>

        <Pivot Grid.Row="1">
            <!-- Liked Tracks -->
            <PivotItem Header="Tracks">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button Content="Play All" Click="PlayAllTracks_Click" Margin="0,8,0,12"
                            x:Name="PlayAllBtn" Visibility="Collapsed"
                            Style="{StaticResource AccentButtonStyle}"/>
                    <ListView x:Name="FavTracksList" Grid.Row="1" IsItemClickEnabled="True"
                              ItemClick="FavTrack_Click" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Track">
                                <Grid Height="56" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="6" Width="44" Height="44">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{x:Bind SmallCoverUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource TrackTitle}"/>
                                        <TextBlock Style="{StaticResource TrackSubtitle}">
                                            <Run Text="{x:Bind ArtistName}"/>
                                            <Run Text=" • "/>
                                            <Run Text="{x:Bind AlbumTitle}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="2" Style="{StaticResource QualityBadge}"
                                            Visibility="{x:Bind QualityBadge, Converter={StaticResource StringVisibility}}"
                                            Margin="8,0">
                                        <TextBlock Text="{x:Bind QualityBadge}" Style="{StaticResource BadgeText}"/>
                                    </Border>
                                    <TextBlock Grid.Column="3" Text="{x:Bind DurationString}"
                                               VerticalAlignment="Center" Opacity="0.6" FontSize="12"
                                               TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel x:Name="EmptyTracks" Grid.Row="1" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Spacing="8" Visibility="Collapsed">
                        <FontIcon Glyph="&#xEB51;" FontSize="40" Opacity="0.3"/>
                        <TextBlock Text="No liked tracks yet" Opacity="0.5"/>
                    </StackPanel>
                </Grid>
            </PivotItem>

            <!-- Albums -->
            <PivotItem Header="Albums">
                <GridView x:Name="FavAlbumsGrid" IsItemClickEnabled="True" ItemClick="FavAlbum_Click"
                          SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:AlbumDetail">
                            <Border Style="{StaticResource CardBorder}" Width="160" Margin="4">
                                <StackPanel Spacing="8">
                                    <Border CornerRadius="8" Height="140" Width="140">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{x:Bind CoverUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="{x:Bind Title}" Style="{StaticResource TrackTitle}" MaxWidth="140"/>
                                    <TextBlock Text="{x:Bind ArtistName}" Style="{StaticResource TrackSubtitle}" MaxWidth="140"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </PivotItem>

            <!-- Artists -->
            <PivotItem Header="Artists">
                <GridView x:Name="FavArtistsGrid" IsItemClickEnabled="True" ItemClick="FavArtist_Click"
                          SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:ArtistDetail">
                            <StackPanel Width="140" Spacing="8" Margin="4" HorizontalAlignment="Center">
                                <Ellipse Width="120" Height="120">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{x:Bind ImageUrl}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource TrackTitle}"
                                           TextAlignment="Center" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>

