<Page
    xmlns:helpers="using:DroidTidal.Helpers"
    x:Class="DroidTidal.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DroidTidal.Models">
    <Page.Resources>
        <helpers:StringToVisibilityConverter x:Key="StringVisibility"/>
    </Page.Resources>

    <Grid Padding="0,0,0,100">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Search" Style="{StaticResource PageHeader}" Grid.Row="0"/>

        <!-- Search Box -->
        <AutoSuggestBox x:Name="SearchBox" Grid.Row="1"
                        PlaceholderText="Search for tracks, artists, albums..."
                        QueryIcon="Find"
                        QuerySubmitted="SearchBox_QuerySubmitted"
                        TextChanged="SearchBox_TextChanged"
                        Margin="0,0,0,16"/>

        <!-- Results -->
        <Pivot x:Name="ResultsPivot" Grid.Row="2">
            <!-- Tracks Tab -->
            <PivotItem Header="Tracks">
                <ListView x:Name="TracksList" ItemClick="Track_Click" IsItemClickEnabled="True"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Track">
                            <Grid Height="56" Padding="0,4" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="6" Width="44" Height="44">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{x:Bind SmallCoverUrl}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                    <TextBlock Text="{x:Bind Title}" Style="{StaticResource TrackTitle}"/>
                                    <TextBlock Style="{StaticResource TrackSubtitle}">
                                        <Run Text="{x:Bind ArtistName}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{x:Bind AlbumTitle}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="2" Style="{StaticResource QualityBadge}"
                                        Visibility="{x:Bind QualityBadge, Converter={StaticResource StringVisibility}}"
                                        Margin="8,0">
                                    <TextBlock Text="{x:Bind QualityBadge}" Style="{StaticResource BadgeText}"/>
                                </Border>
                                <TextBlock Grid.Column="3" Text="{x:Bind DurationString}"
                                           VerticalAlignment="Center" Opacity="0.6" FontSize="12" MinWidth="40"
                                           TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <!-- Artists Tab -->
            <PivotItem Header="Artists">
                <GridView x:Name="ArtistGrid" ItemClick="Artist_Click" IsItemClickEnabled="True"
                          SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:ArtistSearchResult">
                            <StackPanel Width="140" Spacing="8" Margin="4" HorizontalAlignment="Center">
                                <Ellipse Width="120" Height="120">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{x:Bind ImageUrl}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource TrackTitle}"
                                           TextAlignment="Center" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </PivotItem>

            <!-- Albums Tab -->
            <PivotItem Header="Albums">
                <GridView x:Name="AlbumGrid" ItemClick="Album_Click" IsItemClickEnabled="True"
                          SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:AlbumSearchResult">
                            <Border Style="{StaticResource CardBorder}" Width="160" Margin="4">
                                <StackPanel Spacing="8">
                                    <Border CornerRadius="8" Height="140" Width="140">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{x:Bind CoverUrl}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="{x:Bind Title}" Style="{StaticResource TrackTitle}" MaxWidth="140"/>
                                    <TextBlock Style="{StaticResource TrackSubtitle}" MaxWidth="140">
                                        <Run Text="{x:Bind ArtistName}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{x:Bind Year}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </PivotItem>
        </Pivot>

        <!-- Loading -->
        <ProgressRing x:Name="LoadingRing" Grid.Row="2" IsActive="False"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Page>

